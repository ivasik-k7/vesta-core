  "types": [
    {
      "name": "Attestation",
      "docs": [
        "A signed credential binding a subject wallet to a value under a schema.",
        "",
        "FIELD ORDER IS AN ABI. argus reads this account by fixed byte offset",
        "(`argus::constants::attestation_offset`) rather than linking the aegis",
        "crate. The layout below MUST stay: disc(8) · issuer(32) · subject(32) ·",
        "schema(u16) · value(u64) · issued_at(i64) · expires_at(i64) · revoked(bool)",
        "· bump(u8). Reordering breaks every guard that gates on attestation."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "issuer",
            "type": "pubkey"
          },
          {
            "name": "subject",
            "type": "pubkey"
          },
          {
            "name": "schema",
            "type": "u16"
          },
          {
            "name": "value",
            "docs": [
              "Schema-defined payload — typically a bitmask (regions, tiers)."
            ],
            "type": "u64"
          },
          {
            "name": "issued_at",
            "type": "i64"
          },
          {
            "name": "expires_at",
            "docs": [
              "Unix expiry; 0 means never expires."
            ],
            "type": "i64"
          },
          {
            "name": "revoked",
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "AttestationData",
      "docs": [
        "Payload shared by issue/update — one struct, one validation path."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "schema",
            "type": "u16"
          },
          {
            "name": "value",
            "type": "u64"
          },
          {
            "name": "expires_at",
            "docs": [
              "Unix expiry; 0 = never."
            ],
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "AttestationIssued",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "issuer",
            "type": "pubkey"
          },
          {
            "name": "subject",
            "type": "pubkey"
          },
          {
            "name": "schema",
            "type": "u16"
          },
          {
            "name": "value",
            "type": "u64"
          },
          {
            "name": "expires_at",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "AttestationRevoked",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "issuer",
            "type": "pubkey"
          },
          {
