                "u8",
                32
              ]
            }
          },
          {
            "name": "standard_uri",
            "type": "string"
          },
          {
            "name": "sas_schema",
            "docs": [
              "Optional alias to a SAS schema account."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "deprecated",
            "type": "bool"
          },
          {
            "name": "successor",
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
